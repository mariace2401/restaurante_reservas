# Database (producción)
DATABASE_URL=postgresql://usuario:password@host:puerto/nombre_db?sslmode=require

# Database (desarrollo local con Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reservibe
DB_USER=postgres
